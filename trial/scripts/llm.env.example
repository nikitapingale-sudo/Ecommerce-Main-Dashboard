# ============================================================
#  Backend secrets for scripts/api.py + dbm.py — TEMPLATE
#  → Copy this file to  scripts/llm.env  and fill in the values.
#  → scripts/llm.env is gitignored — NEVER commit real credentials.
#  Then restart the API:  npm run api
# ============================================================

# ── Chatbot (Groq) ──  Get a key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.4
GROQ_MAX_TOKENS=900

# ── Trino connection (required for live data) ──
TRINO_HOST=
TRINO_PORT=443
TRINO_USER=
TRINO_PASSWORD=
TRINO_CATALOG=cdp
