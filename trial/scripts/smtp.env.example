# ============================================================
#  SMTP config for password-reset emails (Gmail)
#  → Copy this file to  scripts/smtp.env  and fill in your values.
#  → Do NOT commit smtp.env (it holds your app password).
#
#  Gmail App Password setup (one-time):
#    1. Enable 2-Step Verification on the Google account:
#       https://myaccount.google.com/security
#    2. Create an App Password:
#       https://myaccount.google.com/apppasswords
#       (pick "Mail" → "Other", name it "PW Orders") → Google shows a
#       16-character password like "abcd efgh ijkl mnop".
#    3. Put that 16-char value (spaces optional) as SMTP_PASS below.
#  Then restart the API:  npm run api
# ============================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_sender@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM=your_sender@gmail.com
