# ============================================================
#  PW Orders Intelligence Hub — .gitignore
# ============================================================

# ── Dependencies ──────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ── Build Outputs ─────────────────────────────────────────────
dist/
dist-ssr/
build/
out/
.output/

# ── Environment Files (NEVER commit real env files) ───────────
.env
.env.development
.env.production
.env.staging
.env.local
.env.*.local
# SAFE to commit:
# .env.example  ← keep this, it's just a template

# ── Secrets for backend scripts (NEVER commit — they hold API keys) ──
scripts/smtp.env
scripts/llm.env
# SAFE to commit: scripts/*.env.example (templates only)

# ── User data / auth logs (PLAINTEXT credentials — never commit) ──
scripts/users.json
scripts/auth_log.jsonl
scripts/reset_codes.log

# ── Python build artifacts ──
__pycache__/
*.py[cod]
*.pyc

# ── Vite ──────────────────────────────────────────────────────
.vite/
vite.config.js.timestamp-*

# ── Editor / IDE ──────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Testing ───────────────────────────────────────────────────
coverage/
.nyc_output/
test-results/
playwright-report/

# ── Misc ──────────────────────────────────────────────────────
*.local
*.backup
*.bak
*.orig
.cache/
tmp/
temp/

# ── DBM / Scripts Output ──────────────────────────────────────
scripts/output/
scripts/tmp/
data/raw/
data/exports/*.xlsx
data/exports/*.csv
!data/exports/.gitkeep

# ── Vercel ────────────────────────────────────────────────────
.vercel/

.vercel
