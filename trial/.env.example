# ============================================================
#  PW Orders Intelligence Hub — ENV EXAMPLE / TEMPLATE
# ============================================================
#  HOW TO USE:
#    1. Copy this file:  cp .env.example .env.development
#    2. Fill in your actual values
#    3. Never commit .env.development or .env.production to Git
#
#  Variables prefixed with VITE_ are exposed to the browser.
#  Variables WITHOUT VITE_ prefix are server/script-only (DB, etc.)
# ============================================================

# ── App ──────────────────────────────────────────────────────
VITE_APP_NAME="PW Orders Intelligence Hub"
VITE_APP_VERSION="1.0.0"
VITE_APP_ENV=""                     # "development" | "staging" | "production"
VITE_APP_BASE_URL=""                # e.g. http://localhost:5173

# ── API / Data Source ─────────────────────────────────────────
VITE_DATA_SOURCE=""                 # "static" | "api"
VITE_API_BASE_URL=""                # e.g. https://api.yourcompany.com/v1
VITE_API_KEY=""                     # Your API key
VITE_API_TIMEOUT_MS=30000

# ── Database (backend/DBM scripts only — not exposed to browser) ──
DB_HOST=""                          # e.g. localhost or RDS endpoint
DB_PORT=5432
DB_NAME=""                          # e.g. pw_orders_prod
DB_USER=""                          # DB username
DB_PASSWORD=""                      # DB password
DB_SCHEMA="mview"
DB_TABLE="gold_dbt_vinniculum_orders_base_fact"
DB_SSL=false                        # true in production
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Snowflake (optional) ──────────────────────────────────────
# VITE_SNOWFLAKE_ACCOUNT=""
# VITE_SNOWFLAKE_WAREHOUSE=""
# VITE_SNOWFLAKE_DATABASE=""
# VITE_SNOWFLAKE_SCHEMA=""
# VITE_SNOWFLAKE_ROLE=""

# ── Auth ──────────────────────────────────────────────────────
VITE_AUTH_ENABLED=false             # true | false
VITE_AUTH_PROVIDER=""               # "none" | "google" | "okta" | "azure"
VITE_AUTH_CLIENT_ID=""
VITE_AUTH_DOMAIN=""
VITE_AUTH_ALLOWED_DOMAINS=""        # comma-separated: "company.com,partner.com"

# ── Feature Flags ─────────────────────────────────────────────
VITE_FEATURE_AUTO_REFRESH=true
VITE_AUTO_REFRESH_INTERVAL_SEC=3600
VITE_FEATURE_EXCEL_EXPORT=true
VITE_FEATURE_PENDENCY_PAGE=true
VITE_FEATURE_RAW_DATA_PAGE=true
VITE_FEATURE_DEBUG_PANEL=false

# ── Analytics / Monitoring ────────────────────────────────────
VITE_ANALYTICS_ENABLED=false
VITE_SENTRY_DSN=""
VITE_POSTHOG_KEY=""
VITE_POSTHOG_HOST=""

# ── Vercel ────────────────────────────────────────────────────
VERCEL_ENV=""                       # "development" | "preview" | "production"
VERCEL_URL=""                       # Auto-set by Vercel, override locally
